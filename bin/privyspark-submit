#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: $0 scan --path <ABS_PATH> --output <ABS_PATH> [--ruleset default|/abs/path/to/rules.yaml] [--sample-ratio 0.2]"
  exit 1
fi

DEFAULT_JAR="$(ls -1 build/libs/privyspark-*.jar 2>/dev/null | head -n 1 || true)"
APP_JAR="${PRIVYSPARK_APP_JAR:-${DEFAULT_JAR}}"
MAIN_CLASS="io.github.jonggeun2001.privyspark.PrivySparkApp"
PACKAGES="${PRIVYSPARK_PACKAGES:-com.github.scopt:scopt_2.12:4.1.0,org.yaml:snakeyaml:2.2,com.crealytics:spark-excel_2.12:3.5.1_0.20.4}"
SPARK_FILES="${PRIVYSPARK_SPARK_FILES:-config/rules/default.yaml#default-rules.yaml}"

if [[ -z "${APP_JAR}" || ! -f "${APP_JAR}" ]]; then
  echo "Application jar not found. Build first: ./gradlew clean jar"
  echo "Or set PRIVYSPARK_APP_JAR explicitly."
  exit 1
fi

spark-submit \
  --class "${MAIN_CLASS}" \
  --master yarn \
  --deploy-mode cluster \
  --packages "${PACKAGES}" \
  --files "${SPARK_FILES}" \
  "${APP_JAR}" \
  "$@"
