#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: $0 scan --path <ABS_PATH> --output <ABS_PATH> [--ruleset default|/abs/path/to/rules.yaml] [--sample-ratio 0.2]"
  exit 1
fi

DEFAULT_JAR="$(ls -1 build/libs/privyspark-*-all.jar 2>/dev/null | head -n 1 || true)"
APP_JAR="${PRIVYSPARK_APP_JAR:-${DEFAULT_JAR}}"
MAIN_CLASS="io.github.jonggeun2001.privyspark.PrivySparkApp"
SPARK_FILES="${PRIVYSPARK_SPARK_FILES:-config/rules/default.yaml#default-rules.yaml}"
PACKAGES="${PRIVYSPARK_PACKAGES:-}"

if [[ -z "${APP_JAR}" || ! -f "${APP_JAR}" ]]; then
  echo "Application jar not found. Build first: ./gradlew clean shadowJar"
  echo "Or set PRIVYSPARK_APP_JAR explicitly."
  exit 1
fi

PACKAGE_ARGS=()
if [[ -n "${PACKAGES}" ]]; then
  PACKAGE_ARGS=(--packages "${PACKAGES}")
fi

spark-submit \
  --class "${MAIN_CLASS}" \
  --master yarn \
  --deploy-mode cluster \
  "${PACKAGE_ARGS[@]}" \
  --files "${SPARK_FILES}" \
  "${APP_JAR}" \
  "$@"
